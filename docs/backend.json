
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Details for an authenticated intelligence officer.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "badgeId": { "type": "string" },
        "department": { "type": "string" },
        "role": { "type": "string", "enum": ["Officer", "Analyst", "Admin"] }
      },
      "required": ["uid", "email", "badgeId", "role"]
    },
    "SocialMediaMessage": {
      "title": "SocialMediaMessage",
      "type": "object",
      "description": "Represents a social media message analyzed for potential harm.",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "emotionalIntensityScore": { "type": "number" },
        "callToActionScore": { "type": "number" },
        "contextMismatchScore": { "type": "number" },
        "harmScore": { "type": "number" },
        "analysisDate": { "type": "string", "format": "date-time" },
        "officerId": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "url": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "aiSummary": { "type": "string" }
      },
      "required": ["id", "text", "harmScore", "analysisDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Officer profiles and roles."
    },
    "/socialMediaMessages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/SocialMediaMessage" },
      "description": "Historical record of all analyzed intelligence."
    }
  }
}
